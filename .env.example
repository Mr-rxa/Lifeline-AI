# Copy this file to .env for local development.
# Keep .env private; it is ignored by git.

# Shared
DATABASE_URL=sqlite:///lifeline.db
ORS_API_KEY=

# Flask app
SECRET_KEY=
JWT_SECRET_KEY=

# FastAPI backend
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=*

# Local demo seed passwords.
# Leave blank to generate one-time local passwords during seeding/startup.
SEED_ADMIN_EMAIL=admin@lifeline.ai
SEED_ADMIN_PASSWORD=
SEED_DISPATCHER_PASSWORD=
SEED_DRIVER_PASSWORD=
SEED_HOSPITAL_PASSWORD=
SEED_CITIZEN_PASSWORD=
